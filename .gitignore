# Dependencias (NUNCA subir esto)
node_modules/
jspm_packages/

# Resultados de compilación (el código listo para el servidor web)
# Aunque es código, se genera automáticamente, no se sube el "build" 
# a menos que uses un método de despliegue específico.
/build
/dist
/out

# Archivos de registro (Logs)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Variables de entorno (Contienen contraseñas o llaves de API)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Archivos del Editor/Sistema
.vscode/
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Archivos de caché
.eslintcache
.stylelintcache
.cache/
